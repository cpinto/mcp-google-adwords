GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
# Optional: for manager/MCC accounts
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# --- Authentication (choose one) ---

# Option 1: Service account (preferred — no token expiry)
# Place a service_account.json in the project directory, or set the path:
# GOOGLE_ADS_SERVICE_ACCOUNT_PATH=/path/to/service_account.json
# Optional: impersonate a user (required for domain-wide delegation)
# GOOGLE_ADS_IMPERSONATED_EMAIL=user@domain.com

# Option 2: OAuth (client ID/secret required; refresh token can be created via the `authorize` MCP tool)
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
